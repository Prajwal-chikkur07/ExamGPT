# Copy this file to .env.production on your server.
# Never commit the real .env.production file.

GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

POSTGRES_USER=examgpt
POSTGRES_PASSWORD=change_this_to_a_long_random_password
POSTGRES_DB=examgpt

# Public browser-visible backend URL.
# Examples:
# NEXT_PUBLIC_API_URL=https://api.yourdomain.com
# NEXT_PUBLIC_API_URL=https://yourdomain.com
NEXT_PUBLIC_API_URL=https://api.yourdomain.com

# Frontend origin(s) allowed to call the backend.
CORS_ORIGINS=https://yourdomain.com

FRONTEND_PORT=3000
BACKEND_PORT=8001
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
RETRIEVE_TOP_K=12
RERANK_TOP_K=4
RRF_K=60
HISTORY_WINDOW=10
